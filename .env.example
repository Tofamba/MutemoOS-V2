# ── Firecrawl ─────────────────────────────────────────────────────────────────
# Get your key at https://firecrawl.dev — free tier gives 500 credits/month
FIRECRAWL_API_KEY=fc-your-key-here

# ── MutemoOS webhook target ───────────────────────────────────────────────────
# The MutemoOS instance this feed service pushes content to
MUTEMOS_BASE_URL=https://mutemoos-production.up.railway.app
MUTEMOS_ADMIN_TOKEN=your-mutemos-admin-token-here
MUTEMOS_FIRM_ID=a1b2c3d4-0000-0000-0000-000000000001   # Sawyer & Mkushi firm UUID

# ── Feed service auth ─────────────────────────────────────────────────────────
# Protects the /trigger/* and /failures endpoints
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FEED_ADMIN_TOKEN=your-feed-admin-token-here

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to persistent volume on Railway (mount at /data)
DATA_DIR=/data

# ── Dry run ───────────────────────────────────────────────────────────────────
# Set to "true" to scrape and log without pushing to MutemoOS
# Use this for initial testing before going live
DRY_RUN=false
